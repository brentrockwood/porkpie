POSTGRES_DB=replace_with_local_database_name
POSTGRES_USER=replace_with_local_database_user
POSTGRES_PASSWORD=replace_with_local_database_password

# Optional model-backed task classifier used by the server container.
# For the demo environment, set OLLAMA_BASE_URL to the available Ollama host.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_MS=5000
