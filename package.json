{
  "name": "porkpie",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:system": "npm run test:system -w @porkpie/server",
    "test:e2e": "./scripts/browser-smoke.sh",
    "seed": "npm run seed -w @porkpie/server",
    "scan:containers": "./scripts/scan-containers.sh",
    "lint": "eslint client/src server/src server/tests shared/src",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "typescript-eslint": "8.63.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-musl": "4.62.2"
  }
}
