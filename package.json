{
  "name": "porkpie",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:system": "npm run test:system -w @porkpie/server",
    "test:e2e": "./scripts/browser-smoke.sh",
    "scan:containers": "./scripts/scan-containers.sh",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
